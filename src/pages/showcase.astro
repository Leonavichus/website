---
/**
 * Component Showcase
 * Demo page for all Material Design 3 components
 */
import Avatar from '../components/ui/Avatar.astro';
import AvatarGroup from '../components/ui/AvatarGroup.astro';
import Slider from '../components/ui/Slider.astro';
import Switch from '../components/ui/Switch.astro';
import TreeView from '../components/ui/TreeView.astro';
import SearchBar from '../components/ui/SearchBar.astro';
import Accordion from '../components/ui/Accordion.astro';
import Alert from '../components/ui/Alert.astro';
import ProgressCircle from '../components/ui/ProgressCircle.astro';
import Pagination from '../components/ui/Pagination.astro';
import Breadcrumbs from '../components/ui/Breadcrumbs.astro';
import Rating from '../components/ui/Rating.astro';
import Timeline from '../components/ui/Timeline.astro';
import StatCard from '../components/ui/StatCard.astro';
import ColorPicker from '../components/ui/ColorPicker.astro';
import Ripple from '../components/ui/Ripple.astro';
import DataTable from '../components/ui/DataTable.astro';
import DatePicker from '../components/ui/DatePicker.astro';
import TimePicker from '../components/ui/TimePicker.astro';
import DateRangePicker from '../components/ui/DateRangePicker.astro';
import FileUpload from '../components/ui/FileUpload.astro';
import Form from '../components/ui/Form.astro';
import FormField from '../components/ui/FormField.astro';
import Stepper from '../components/ui/Stepper.astro';
import Autocomplete from '../components/ui/Autocomplete.astro';
import Backdrop from '../components/ui/Backdrop.astro';
import NavigationRail from '../components/ui/NavigationRail.astro';
import SkeletonLoader from '../components/ui/SkeletonLoader.astro';
import EmptyState from '../components/ui/EmptyState.astro';
import ValidationMessage from '../components/ui/ValidationMessage.astro';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Material Design 3 - Component Showcase</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      /* Material Design 3 Colors */
      --md-sys-color-primary: #6750A4;
      --md-sys-color-on-primary: #FFFFFF;
      --md-sys-color-primary-container: #EADDFF;
      --md-sys-color-on-primary-container: #21005D;

      --md-sys-color-secondary: #625B71;
      --md-sys-color-on-secondary: #FFFFFF;
      --md-sys-color-secondary-container: #E8DEF8;
      --md-sys-color-on-secondary-container: #1D192B;

      --md-sys-color-tertiary: #7D5260;
      --md-sys-color-on-tertiary: #FFFFFF;
      --md-sys-color-tertiary-container: #FFD8E4;
      --md-sys-color-on-tertiary-container: #31111D;

      --md-sys-color-error: #B3261E;
      --md-sys-color-on-error: #FFFFFF;
      --md-sys-color-error-container: #F9DEDC;
      --md-sys-color-on-error-container: #410E0B;

      --md-sys-color-surface: #FFFBFE;
      --md-sys-color-on-surface: #1C1B1F;
      --md-sys-color-surface-variant: #E7E0EC;
      --md-sys-color-on-surface-variant: #49454F;
      --md-sys-color-surface-container: #F3EDF7;
      --md-sys-color-surface-container-low: #F7F2FA;
      --md-sys-color-surface-container-high: #ECE6F0;
      --md-sys-color-surface-container-highest: #E6E0E9;

      --md-sys-color-outline: #79747E;
      --md-sys-color-outline-variant: #CAC4D0;

      /* Shape */
      --md-sys-shape-corner-none: 0px;
      --md-sys-shape-corner-extra-small: 4px;
      --md-sys-shape-corner-small: 8px;
      --md-sys-shape-corner-medium: 12px;
      --md-sys-shape-corner-large: 16px;
      --md-sys-shape-corner-extra-large: 28px;
      --md-sys-shape-corner-full: 9999px;

      /* Elevation */
      --md-sys-elevation-0: none;
      --md-sys-elevation-1: 0 1px 3px rgba(0, 0, 0, 0.12);
      --md-sys-elevation-2: 0 2px 6px rgba(0, 0, 0, 0.15);
      --md-sys-elevation-3: 0 4px 8px rgba(0, 0, 0, 0.18);
      --md-sys-elevation-4: 0 8px 12px rgba(0, 0, 0, 0.20);
      --md-sys-elevation-5: 0 12px 16px rgba(0, 0, 0, 0.22);
    }

    body {
      font-family: 'Roboto', system-ui, -apple-system, sans-serif;
      background: var(--md-sys-color-surface);
      color: var(--md-sys-color-on-surface);
      line-height: 1.6;
      padding: 24px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    h1 {
      font-size: 48px;
      font-weight: 400;
      margin-bottom: 8px;
      color: var(--md-sys-color-primary);
    }

    h2 {
      font-size: 32px;
      font-weight: 400;
      margin-top: 48px;
      margin-bottom: 24px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--md-sys-color-outline-variant);
    }

    h3 {
      font-size: 24px;
      font-weight: 500;
      margin-top: 32px;
      margin-bottom: 16px;
    }

    .section {
      margin-bottom: 48px;
    }

    .demo-box {
      padding: 24px;
      margin: 16px 0;
      border-radius: var(--md-sys-shape-corner-large);
      background: var(--md-sys-color-surface-container-low);
    }

    .demo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      margin: 24px 0;
    }

    .demo-row {
      display: flex;
      gap: 16px;
      align-items: center;
      flex-wrap: wrap;
      margin: 16px 0;
    }

    .code-block {
      background: var(--md-sys-color-surface-container-highest);
      padding: 16px;
      border-radius: var(--md-sys-shape-corner-medium);
      font-family: 'Roboto Mono', monospace;
      font-size: 14px;
      overflow-x: auto;
      margin: 12px 0;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Material Design 3</h1>
    <p style="font-size: 20px; margin-bottom: 48px; color: var(--md-sys-color-on-surface-variant);">
      Component Showcase - 30 полностью функциональных компонентов
    </p>

    <!-- 1. AVATAR -->
    <section class="section">
      <h2>1. Avatar & Avatar Group</h2>

      <h3>Single Avatar</h3>
      <div class="demo-row">
        <Avatar alt="John Doe" size="small" />
        <Avatar alt="Jane Smith" size="medium" />
        <Avatar alt="Bob Wilson" size="large" />
        <Avatar 
          src="https://i.pravatar.cc/150?img=1" 
          alt="User 1" 
          status="online"
        />
        <Avatar alt="AB" badge={5} />
      </div>

      <h3>Avatar Group</h3>
      <div class="demo-box">
        <AvatarGroup 
          avatars={[
            { alt: 'User 1', src: 'https://i.pravatar.cc/150?img=1' },
            { alt: 'User 2', src: 'https://i.pravatar.cc/150?img=2' },
            { alt: 'User 3', src: 'https://i.pravatar.cc/150?img=3' },
            { alt: 'User 4', src: 'https://i.pravatar.cc/150?img=4' },
            { alt: 'User 5', src: 'https://i.pravatar.cc/150?img=5' },
          ]}
          max={3}
        />
      </div>
    </section>

    <!-- 2. FORMS -->
    <section class="section">
      <h2>2. Forms & Inputs</h2>

      <h3>Form Field</h3>
      <div class="demo-box">
        <FormField label="Username" helperText="Enter your username" fullWidth>
          <input type="text" style="padding: 12px; border: 1px solid var(--md-sys-color-outline); border-radius: 8px; width: 100%;" />
        </FormField>
      </div>

      <h3>Autocomplete</h3>
      <div class="demo-box">
        <Autocomplete
          id="country"
          label="Country"
          options={[
            { value: 'us', label: 'United States', icon: 'flag' },
            { value: 'uk', label: 'United Kingdom', icon: 'flag' },
            { value: 'ca', label: 'Canada', icon: 'flag' },
          ]}
          fullWidth
        />
      </div>

      <h3>Slider</h3>
      <div class="demo-box">
        <Slider name="volume" min={0} max={100} value={50} step={5} />
      </div>

      <h3>Switch</h3>
      <div class="demo-row">
        <Switch name="switch1" label="Notifications" />
        <Switch name="switch2" label="Dark Mode" checked />
        <Switch name="switch3" label="Disabled" disabled />
      </div>

      <h3>Rating</h3>
      <div class="demo-row">
        <Rating id="rating1" value={4} showValue />
        <Rating id="rating2" value={3.5} />
        <Rating id="rating3" value={5} readonly size="large" />
      </div>

      <h3>Color Picker</h3>
      <div class="demo-box">
        <ColorPicker
          id="color"
          label="Theme Color"
          value="#6750A4"
          fullWidth
        />
      </div>
    </section>

    <!-- 3. DATE & TIME -->
    <section class="section">
      <h2>3. Date & Time Pickers</h2>

      <div class="demo-grid">
        <div class="demo-box">
          <h3>Date Picker</h3>
          <DatePicker id="date" label="Select Date" />
        </div>

        <div class="demo-box">
          <h3>Time Picker</h3>
          <TimePicker id="time" label="Select Time" />
        </div>
      </div>

      <div class="demo-box">
        <h3>Date Range Picker</h3>
        <DateRangePicker id="daterange" label="Select Date Range" />
      </div>
    </section>

    <!-- 4. FILE UPLOAD -->
    <section class="section">
      <h2>4. File Upload</h2>
      <div class="demo-box">
        <FileUpload
          id="files"
          label="Upload Files"
          accept="image/*,.pdf"
          multiple
          maxSize={5}
        />
      </div>
    </section>

    <!-- 5. DATA TABLE -->
    <section class="section">
      <h2>5. Data Table</h2>
      <div class="demo-box">
        <DataTable
          columns={[
            { key: 'name', label: 'Name', sortable: true },
            { key: 'email', label: 'Email', sortable: true },
            { key: 'role', label: 'Role', sortable: true },
            { key: 'status', label: 'Status' }
          ]}
          data={[
            { id: 1, name: 'John Doe', email: 'john@example.com', role: 'Admin', status: 'Active' },
            { id: 2, name: 'Jane Smith', email: 'jane@example.com', role: 'User', status: 'Active' },
            { id: 3, name: 'Bob Wilson', email: 'bob@example.com', role: 'User', status: 'Inactive' }
          ]}
        />
      </div>
    </section>

    <!-- 6. PAGINATION -->
    <section class="section">
      <h2>6. Pagination</h2>
      <div class="demo-box">
        <Pagination
          currentPage={3}
          totalPages={10}
          showFirstLast
        />
      </div>
    </section>

    <!-- 7. BREADCRUMBS -->
    <section class="section">
      <h2>7. Breadcrumbs</h2>
      <div class="demo-box">
        <Breadcrumbs
          items={[
            { label: 'Dashboard', href: '#' },
            { label: 'Projects', href: '#' },
            { label: 'Web App', href: '#' },
            { label: 'Components' }
          ]}
        />
      </div>
    </section>

    <!-- 8. NAVIGATION -->
    <section class="section">
      <h2>8. Navigation</h2>

      <h3>Navigation Rail</h3>
      <div class="demo-box" style="height: 400px; position: relative;">
        <NavigationRail
          items={[
            { label: 'Home', icon: 'home', active: true },
            { label: 'Search', icon: 'search' },
            { label: 'Library', icon: 'library_books' },
            { label: 'Profile', icon: 'person' }
          ]}
          showFab
        />
      </div>

      <h3>Tree View</h3>
      <div class="demo-box">
        <TreeView
          nodes={[
            {
              id: '1',
              label: 'Documents',
              icon: 'folder',
              expanded: true,
              children: [
                { id: '1-1', label: 'Report.pdf', icon: 'description' },
                { id: '1-2', label: 'Invoice.xlsx', icon: 'table_chart' }
              ]
            },
            {
              id: '2',
              label: 'Images',
              icon: 'folder',
              children: [
                { id: '2-1', label: 'Photo1.jpg', icon: 'image' },
                { id: '2-2', label: 'Photo2.png', icon: 'image' }
              ]
            }
          ]}
        />
      </div>
    </section>

    <!-- 9. SEARCH -->
    <section class="section">
      <h2>9. Search Bar</h2>
      <div class="demo-box">
        <SearchBar
          placeholder="Search..."
          suggestions={[
            { value: 'react', label: 'React', description: 'JavaScript library' },
            { value: 'vue', label: 'Vue.js', description: 'Progressive framework' },
            { value: 'angular', label: 'Angular', description: 'Platform for web apps' }
          ]}
          fullWidth
        />
      </div>
    </section>

    <!-- 10. ALERTS & NOTIFICATIONS -->
    <section class="section">
      <h2>10. Alerts & Notifications</h2>

      <div class="demo-box">
        <Alert variant="info" title="Information" dismissible>
          This is an informational message.
        </Alert>
      </div>

      <div class="demo-box">
        <Alert variant="success" title="Success">
          Your changes have been saved successfully!
        </Alert>
      </div>

      <div class="demo-box">
        <Alert variant="warning" title="Warning">
          Please review your input before submitting.
        </Alert>
      </div>

      <div class="demo-box">
        <Alert variant="error" title="Error" dismissible>
          An error occurred. Please try again.
        </Alert>
      </div>

      <div class="demo-box">
        <ValidationMessage
          visible
          errors={[
            { field: 'Email', message: 'Invalid email format' },
            { field: 'Password', message: 'Must be at least 8 characters' }
          ]}
        />
      </div>
    </section>

    <!-- 11. PROGRESS -->
    <section class="section">
      <h2>11. Progress Indicators</h2>

      <h3>Progress Circle</h3>
      <div class="demo-row">
        <ProgressCircle value={75} showValue />
        <ProgressCircle value={50} color="secondary" label="Storage" />
        <ProgressCircle value={90} color="tertiary" size={80} />
      </div>
    </section>

    <!-- 12. STATISTICS -->
    <section class="section">
      <h2>12. Statistics Cards</h2>

      <div class="demo-grid">
        <StatCard
          title="Total Users"
          value="2,543"
          icon="people"
          trend="up"
          trendValue="+12.5%"
          description="vs last month"
        />

        <StatCard
          title="Revenue"
          value="$45.2K"
          icon="payments"
          trend="up"
          trendValue="+8.2%"
          color="secondary"
        />

        <StatCard
          title="Active Projects"
          value="18"
          icon="folder"
          trend="neutral"
          color="tertiary"
        />
      </div>
    </section>

    <!-- 13. TIMELINE -->
    <section class="section">
      <h2>13. Timeline</h2>

      <div class="demo-box">
        <Timeline
          items={[
            {
              title: 'Project Started',
              description: 'Initial planning and setup',
              date: 'Jan 1, 2026',
              icon: 'flag',
              color: 'primary'
            },
            {
              title: 'Design Phase',
              description: 'UI/UX design completed',
              date: 'Jan 15, 2026',
              icon: 'palette',
              color: 'secondary'
            },
            {
              title: 'Development',
              description: 'Core features implemented',
              date: 'Feb 1, 2026',
              icon: 'code',
              color: 'tertiary'
            },
            {
              title: 'Testing',
              description: 'QA and bug fixes',
              date: 'Mar 1, 2026',
              icon: 'bug_report',
              color: 'success'
            }
          ]}
        />
      </div>
    </section>

    <!-- 14. ACCORDION -->
    <section class="section">
      <h2>14. Accordion</h2>

      <div class="demo-box">
        <Accordion
          items={[
            {
              id: 'item1',
              title: 'What is Material Design?',
              content: 'Material Design is a design system created by Google to help teams build high-quality digital experiences.',
              expanded: true
            },
            {
              id: 'item2',
              title: 'How do I use these components?',
              content: 'Import the component and use it in your Astro pages with the appropriate props.'
            },
            {
              id: 'item3',
              title: 'Are these components customizable?',
              content: 'Yes! All components support CSS custom properties and accept various props for customization.'
            }
          ]}
        />
      </div>
    </section>

    <!-- 15. STEPPER -->
    <section class="section">
      <h2>15. Stepper (Multi-step Form)</h2>

      <div class="demo-box">
        <Stepper
          steps={[
            { label: 'Account Details' },
            { label: 'Payment Info' },
            { label: 'Confirmation' }
          ]}
          currentStep={1}
        />
      </div>
    </section>

    <!-- 16. LOADING STATES -->
    <section class="section">
      <h2>16. Loading States</h2>

      <h3>Skeleton Loader</h3>
      <div class="demo-box">
        <div style="display: flex; flex-direction: column; gap: 12px;">
          <SkeletonLoader variant="text" width="200px" />
          <SkeletonLoader variant="rectangular" width="100%" height="200px" />
          <div style="display: flex; gap: 12px;">
            <SkeletonLoader variant="circular" width="40px" height="40px" />
            <div style="flex: 1;">
              <SkeletonLoader variant="text" width="60%" />
              <SkeletonLoader variant="text" width="40%" />
            </div>
          </div>
        </div>
      </div>

      <h3>Empty State</h3>
      <div class="demo-box">
        <EmptyState
          icon="inbox"
          title="No messages"
          description="You don't have any messages yet"
          actionLabel="Compose Message"
          actionIcon="edit"
        />
      </div>
    </section>

    <!-- 17. BACKDROP -->
    <section class="section">
      <h2>17. Backdrop Overlay</h2>

      <div class="demo-box">
        <button 
          style="padding: 12px 24px; border-radius: 8px; background: var(--md-sys-color-primary); color: white; border: none; cursor: pointer;"
          onclick="document.querySelector('[data-backdrop]').removeAttribute('hidden')"
        >
          Show Backdrop
        </button>

        <Backdrop id="demo-backdrop">
          <div style="background: white; padding: 32px; border-radius: 16px; max-width: 400px;">
            <h3>Backdrop Demo</h3>
            <p style="margin: 16px 0;">This is content displayed on top of the backdrop.</p>
            <button 
              style="padding: 8px 16px; border-radius: 8px; background: var(--md-sys-color-primary); color: white; border: none; cursor: pointer;"
              onclick="document.querySelector('[data-backdrop]').setAttribute('hidden', '')"
            >
              Close
            </button>
          </div>
        </Backdrop>
      </div>
    </section>

    <!-- 18. RIPPLE EFFECT -->
    <section class="section">
      <h2>18. Ripple Effect</h2>

      <div class="demo-box">
        <div style="position: relative; display: inline-block; overflow: hidden; padding: 16px 32px; background: var(--md-sys-color-primary-container); border-radius: 8px; cursor: pointer;">
          Click me for ripple effect
          <Ripple />
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer style="margin-top: 80px; padding-top: 24px; border-top: 1px solid var(--md-sys-color-outline-variant); text-align: center; color: var(--md-sys-color-on-surface-variant);">
      <p>Material Design 3 Component Library</p>
      <p style="margin-top: 8px; font-size: 14px;">30 компонентов • Astro • TypeScript • Material Design 3</p>
    </footer>
  </div>

  <!-- Google Material Symbols -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500&display=swap" />
</body>
</html>
