---
/**
 * DataTable Component - FINAL
 * Material Design 3 data table
 */
import Icon from './Icon.astro';

interface Column {
  key: string;
  label: string;
  sortable?: boolean;
  width?: string;
}

interface Row {
  id: number | string;
  [key: string]: any;
}

interface Props {
  columns: Column[];
  data: Row[];
  selectable?: boolean;
  stickyHeader?: boolean;
}

const {
  columns,
  data,
  selectable = false,
  stickyHeader = false
} = Astro.props;
---

<div class="data-table-wrapper">
  <div class="data-table__toolbar">
    <div class="data-table__search">
      <Icon name="search" />
      <input 
        type="text" 
        placeholder="Search..."
        class="data-table__search-input"
        data-search
      />
    </div>
  </div>

  <div class:list={['data-table-container', { 'data-table-container--sticky': stickyHeader }]}>
    <table class="data-table" data-table>
      <thead class="data-table__head">
        <tr class="data-table__row">
          {selectable && (
            <th class="data-table__cell data-table__cell--checkbox">
              <input type="checkbox" data-select-all />
            </th>
          )}
          {columns.map((column) => (
            <th 
              class:list={[
                'data-table__cell',
                'data-table__cell--header',
                { 'data-table__cell--sortable': column.sortable }
              ]}
              style={column.width ? `width: ${column.width}` : undefined}
              data-key={column.key}
              data-sortable={column.sortable}
            >
              <button 
                type="button"
                class="data-table__sort-button"
                disabled={!column.sortable}
              >
                <span>{column.label}</span>
                {column.sortable && (
                  <span class="data-table__sort-icons">
                    <span class="material-symbols-outlined data-table__sort-arrow data-table__sort-arrow--up">arrow_drop_up</span>
                    <span class="material-symbols-outlined data-table__sort-arrow data-table__sort-arrow--down">arrow_drop_down</span>
                  </span>
                )}
              </button>
            </th>
          ))}
        </tr>
      </thead>

      <tbody class="data-table__body" data-body>
        {data.map((row) => (
          <tr class="data-table__row" data-row-id={row.id}>
            {selectable && (
              <td class="data-table__cell data-table__cell--checkbox">
                <input type="checkbox" value={row.id} data-select />
              </td>
            )}
            {columns.map((column) => (
              <td class="data-table__cell">
                {row[column.key]}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="data-table__footer">
    <div class="data-table__info" data-info>
      <span>Rows per page:</span>
      <select class="data-table__page-size" data-page-size>
        <option value="10">10</option>
        <option value="25">25</option>
        <option value="50">50</option>
        <option value="100">100</option>
      </select>
      <span data-range>1-3 of 3</span>
    </div>

    <div class="data-table__pagination">
      <button type="button" class="data-table__page-button" data-prev>
        <Icon name="chevron_left" />
      </button>
      <button type="button" class="data-table__page-button" data-next>
        <Icon name="chevron_right" />
      </button>
    </div>
  </div>
</div>

<style>
  .data-table-wrapper {
    display: flex;
    flex-direction: column;
    border-radius: var(--md-sys-shape-corner-medium);
    background: var(--md-sys-color-surface);
    overflow: hidden;
  }

  .data-table__toolbar {
    display: flex;
    align-items: center;
    padding: 16px;
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .data-table__search {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: var(--md-sys-shape-corner-full);
    background: var(--md-sys-color-surface-container-highest);
    width: 300px;
  }

  .data-table__search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--md-sys-color-on-surface);
    font: var(--md-sys-typescale-body-medium);
    outline: none;
  }

  .data-table-container {
    overflow-x: auto;
  }

  .data-table-container--sticky .data-table__head {
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table__cell {
    padding: 16px;
    text-align: left;
    color: var(--md-sys-color-on-surface);
    font: var(--md-sys-typescale-body-medium);
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
  }

  .data-table__cell--header {
    background: var(--md-sys-color-surface-container-low);
    font-weight: 500;
    color: var(--md-sys-color-on-surface-variant);
  }

  .data-table__cell--checkbox {
    width: 48px;
    padding: 8px 16px;
  }

  .data-table__sort-button {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 0;
    border: none;
    background: transparent;
    color: inherit;
    font: inherit;
    font-weight: 500;
    cursor: pointer;
    width: 100%;
  }

  .data-table__sort-button:disabled {
    cursor: default;
  }

  .data-table__sort-button:hover:not(:disabled) {
    color: var(--md-sys-color-on-surface);
  }

  .data-table__sort-icons {
    display: flex;
    flex-direction: column;
    margin-left: auto;
    line-height: 1;
  }

  .data-table__sort-arrow {
    font-size: 18px;
    color: var(--md-sys-color-on-surface-variant);
    opacity: 0.5;
    transition: all 0.2s;
  }

  .data-table__sort-arrow--up {
    margin-bottom: -8px;
  }

  .data-table__sort-arrow--down {
    margin-top: -8px;
  }

  .data-table__cell--header[data-sort="asc"] .data-table__sort-arrow--up {
    opacity: 1;
    color: var(--md-sys-color-primary);
  }

  .data-table__cell--header[data-sort="desc"] .data-table__sort-arrow--down {
    opacity: 1;
    color: var(--md-sys-color-primary);
  }

  .data-table__row:hover {
    background: var(--md-sys-color-surface-container-highest);
  }

  .data-table__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px;
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  .data-table__info {
    display: flex;
    align-items: center;
    gap: 16px;
    color: var(--md-sys-color-on-surface-variant);
    font: var(--md-sys-typescale-body-small);
  }

  .data-table__page-size {
    padding: 4px 8px;
    border: 1px solid var(--md-sys-color-outline);
    border-radius: var(--md-sys-shape-corner-extra-small);
    background: var(--md-sys-color-surface);
    color: var(--md-sys-color-on-surface);
    font: var(--md-sys-typescale-body-small);
  }

  .data-table__pagination {
    display: flex;
    gap: 8px;
  }

  .data-table__page-button {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--md-sys-color-on-surface-variant);
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .data-table__page-button:hover:not(:disabled) {
    background: var(--md-sys-color-surface-container-highest);
  }

  .data-table__page-button:disabled {
    opacity: 0.38;
    cursor: not-allowed;
  }
</style>

<script>
  function initDataTable() {
    const tables = document.querySelectorAll('[data-table]');

    tables.forEach(table => {
      const wrapper = table.closest('.data-table-wrapper')!;
      const searchInput = wrapper.querySelector('[data-search]') as HTMLInputElement;
      const body = table.querySelector('[data-body]')!;
      let allRows = Array.from(body.querySelectorAll('tr'));

      searchInput?.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase();

        allRows.forEach(row => {
          const text = row.textContent?.toLowerCase() || '';
          if (text.includes(query)) {
            (row as HTMLElement).style.display = '';
          } else {
            (row as HTMLElement).style.display = 'none';
          }
        });
      });

      wrapper.querySelectorAll('[data-sortable="true"]').forEach(header => {
        const button = header.querySelector('button');
        button?.addEventListener('click', () => {
          const key = (header as HTMLElement).dataset.key!;
          const currentSort = (header as HTMLElement).dataset.sort;
          const newSort = currentSort === 'asc' ? 'desc' : 'asc';

          wrapper.querySelectorAll('[data-sort]').forEach(h => {
            h.removeAttribute('data-sort');
          });

          (header as HTMLElement).dataset.sort = newSort;

          const keyIndex = Array.from(table.querySelectorAll('th')).indexOf(header as HTMLTableCellElement);

          allRows.sort((a, b) => {
            const aValue = a.cells[keyIndex]?.textContent || '';
            const bValue = b.cells[keyIndex]?.textContent || '';

            if (newSort === 'asc') {
              return aValue.localeCompare(bValue);
            } else {
              return bValue.localeCompare(aValue);
            }
          });

          allRows.forEach(row => body.appendChild(row));
        });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDataTable);
  } else {
    initDataTable();
  }

  document.addEventListener('astro:page-load', initDataTable);
</script>
